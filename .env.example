# ─── REFRAME — Environment Variables ───────────────────────────────

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Gemini — Draft API key for free trial generations (3 per visitor)
# Replace with your actual key from aistudio.google.com
GEMINI_DRAFT_API_KEY=your_draft_gemini_key_here

# Security
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
ENCRYPTION_KEY=generate_with_openssl_rand_base64_32

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_FREE_GENERATIONS=3
